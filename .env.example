# =============================================================================
# ORKI — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
#
# In production (Vercel), set these in Project Settings → Environment Variables,
# NOT in a committed file.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED) — PostgreSQL connection string.
# The app reads STORAGE_URL first, then falls back to DATABASE_URL.
#   Local dev (Docker):  postgresql://orki:orki@localhost:5432/orki_dev
#   Supabase (prod):     use the TRANSACTION pooler (port 6543) for serverless,
#                        username form postgres.<project_ref>:
#     postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://orki:orki@localhost:5432/orki_dev
# STORAGE_URL=        # set instead of DATABASE_URL on Vercel if preferred

# Node environment: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase Auth (REQUIRED) — without these the app fails to boot.
# Find them in Supabase Dashboard → Project Settings → API.
#   NEXT_PUBLIC_*  are safe to expose to the browser.
#   SERVICE_ROLE_KEY is SECRET — server-only, never exposed to the client.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated list of admin email addresses allowed into /admin.
SUPABASE_ADMIN_EMAILS=you@example.com

# -----------------------------------------------------------------------------
# Resend — transactional email (order confirmations etc.). RESEND_API_KEY is
# optional: leave it empty and the email subsystem silently no-ops (orders still
# complete). For PRODUCTION you MUST set a verified domain sender, otherwise
# customers receive nothing (the resend.dev sandbox only mails the account owner).
#   Get a key: Resend Dashboard → API Keys (re_...).
#   Verify your domain, then set RESEND_FROM_EMAIL to e.g. orders@orki.sa.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Public base URL of the store — used to build links in emails (the "View order"
# button is omitted if this is unset). e.g. https://orki.sa in production.
ORKI_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Destructive catalog reseed guard. POST /api/seed?force=1 wipes the ENTIRE
# product catalog (admin-gated). As an extra safety latch it ALSO requires this
# flag = 1. Leave UNSET in production so the catalog can never be wiped by a
# single request; set to 1 only during a deliberate local/staging reseed.
# -----------------------------------------------------------------------------
# ALLOW_DESTRUCTIVE_SEED=1
