# =============================================================================
# ORKI — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
# =============================================================================

# PostgreSQL connection string
# Local dev (Docker): postgresql://orki:orki@localhost:5432/orki_dev
# Supabase (prod): postgresql://[user]:[password]@[host]:5432/[db]
DATABASE_URL=postgresql://orki:orki@localhost:5432/orki_dev

# Node environment
NODE_ENV=development

# -----------------------------------------------------------------------------
# Resend — transactional email (Plan 08-07). All optional: leave RESEND_API_KEY
# empty and the email subsystem silently no-ops (orders still complete).
# Get a key: Resend Dashboard → API Keys → Create API Key (re_...).
# For prod, verify a domain and use e.g. orders@orki.sa as RESEND_FROM_EMAIL.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
ORKI_BASE_URL=http://localhost:3000
